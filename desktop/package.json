{
  "name": "cursor2api-desktop",
  "version": "2.7.8",
  "description": "Cursor2API 桌面版 - 系统托盘管理工具",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/crazylin/cursor2api.git"
  },
  "scripts": {
    "dev": "electron . --dev",
    "start": "electron .",
    "build:win": "electron-builder --win --x64 --publish never",
    "build:mac": "electron-builder --mac --x64 --arm64 --publish never",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.cursor2api.desktop",
    "productName": "Cursor2API",
    "copyright": "MIT",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../dist",
        "to": "app/dist",
        "filter": [
          "**/*",
          "!**/*.map",
          "!**/*.d.ts"
        ]
      },
      {
        "from": "../public",
        "to": "app/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../node_modules",
        "to": "app/node_modules",
        "filter": [
          "**/*",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/docs/**",
          "!**/examples/**",
          "!**/.github/**",
          "!**/*.md",
          "!**/README*",
          "!**/CHANGELOG*",
          "!**/LICENSE*",
          "!**/LICENCE*",
          "!**/*.map",
          "!**/*.ts",
          "!**/*.tsx"
        ]
      },
      {
        "from": "../config.yaml",
        "to": "app/config.yaml"
      },
      {
        "from": "../package.json",
        "to": "app/package.json"
      },
      {
        "from": "../eng.traineddata",
        "to": "app/eng.traineddata"
      },
      {
        "from": "../chi_sim.traineddata",
        "to": "app/chi_sim.traineddata"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "extraResources": [
        {
          "from": "node-bin/node.exe",
          "to": "node/node.exe"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cursor2API"
    }
  }
}
